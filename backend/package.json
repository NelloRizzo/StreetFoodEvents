{
  "name": "street-food-event-manager-api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for managing street food events, stands, menus, roles and orders.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --platform node --target node22 --out-dir dist --clean",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "populate:database": "tsx src/scripts/populate-database.ts",
    "reset:database": "tsx src/scripts/reset-database.ts",
    "cleanup:database": "tsx src/scripts/cleanup-database.ts",
    "migrate:add-contest-admin-role": "tsx src/scripts/migrate-add-contest-admin-role.ts",
    "migrate:add-exchange-admin-role": "tsx src/scripts/migrate-add-exchange-admin-role.ts",
    "fix:notti-cilentane": "tsx src/scripts/fix-notti-cilentane.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.0.0",
    "argon2": "^0.44.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.0.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.3",
    "tsup": "^8.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/compression": "^1.7.0",
    "@types/cookie-parser": "^1.4.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/morgan": "^1.9.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "mongodb-memory-server": "^11.1.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
